generator client {
  provider      = "prisma-client-js"
  engineType    = "binary"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Mint {
  id            String   @id @default(cuid())
  tgId          String
  walletAddress String
  number        String
  comment       String   @unique
  amountNano    String
  status        String   @default("awaiting_payment")
  txHash        String?
  metaUri       String?
  nftIndex      String?
  nftAddress    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tgId, createdAt])
  @@index([walletAddress, createdAt])
  @@index([status])
}

model Referral {
  wallet      String   @id    // кошелёк реферала
  referredBy  String          // кошелёк того, кто пригласил
  createdAt   DateTime @default(now())

  @@index([referredBy])
}

model Withdrawal {
  id          String   @id @default(cuid())
  wallet      String          // кошелёк того, кто выводит
  amountNano  String
  status      String   @default("pending")
  txHash      String?
  createdAt   DateTime @default(now())

  @@index([wallet, status])
}